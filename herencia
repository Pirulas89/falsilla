3. La Clase de Conexión (ProductoConection)
¡Ojo aquí! Debes registrar AMBAS clases para que Hibernate entienda la relación.

Java
package com.hibernate.gui.util;

import org.hibernate.SessionFactory;
import org.hibernate.cfg.Configuration;
import com.hibernate.gui.model.*;

public class ProductoConection {
    private static SessionFactory sessionFactory;

    public static SessionFactory getSessionFactory() {
        if (sessionFactory == null) {
            Configuration config = new Configuration();
            config.configure("hibernate.cfg.xml");
            
            // REGISTRAMOS PADRE E HIJA
            config.addAnnotatedClass(Producto.class);
            config.addAnnotatedClass(ProductoPerecedero.class);
            
            sessionFactory = config.buildSessionFactory();
        }
        return sessionFactory;
    }
}

