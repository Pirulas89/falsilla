public void actualizarStock(int productoId, boolean tieneStock) {
    Session session = ProductoConection.getSessionFactory().openSession();
    Transaction tx = session.beginTransaction();

    // 1. Buscamos el producto
    Producto producto = session.get(Producto.class, productoId);
    producto.setTieneStock(tieneStock);

    if (!tieneStock) {
        // 2. Si no hay stock, creamos el "marcado" en la otra tabla
        ProductoAgotado agotado = new ProductoAgotado();
        agotado.setProducto(producto); // Vinculamos ambos
        session.persist(agotado); 
    } else {
        // 3. Si vuelve a haber stock, borramos el registro de la tabla Agotados
        ProductoAgotado agotado = session.get(ProductoAgotado.class, productoId);
        if (agotado != null) {
            session.remove(agotado);
        }
    }

    tx.commit();
    session.close();
}

2. Opción con SQL Nativo (Si no quieres mapear la relación)
Si prefieres no complicarte con objetos y solo quieres que al agotarse se inserte el ID en la segunda tabla por "fuerza bruta":

Java
public void marcarComoAgotado(int id) {
    Session session = ProductoConection.getSessionFactory().openSession();
    Transaction tx = session.beginTransaction();

    // Actualizamos la tabla principal
    session.createNativeQuery("UPDATE producto SET tieneStock = false WHERE id = :id")
           .setParameter("id", id)
           .executeUpdate();

    // Insertamos en la tabla de agotados (solo el ID)
    // Usamos IGNORE por si ya estaba insertado antes
    session.createNativeQuery("INSERT IGNORE INTO agotados (id_producto) VALUES (:id)")
           .setParameter("id", id)
           .executeUpdate();

    tx.commit();
    session.close();
}



