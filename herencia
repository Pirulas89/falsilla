@Entity
@Table(name = "mascotas")
@Data
public class Mascota {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private int id;

    @NotBlank(message = "La mascota debe tener nombre")
    private String nombre;

    @Positive(message = "El peso debe ser mayor a 0")
    private double peso;

    @ManyToOne
    @JoinColumn(name = "id_cliente")
    private Cliente dueño;

    @OneToOne(cascade = CascadeType.ALL)
    @JoinColumn(name = "id_expediente")
    private ExpedienteClinico expediente;
}


public class ClinicaService {

    public void registrarCitaRapida(int clienteId, String nombreMascota, double peso, int vetId) throws Exception {
        Session session = HibernateUtil.getSessionFactory().openSession();
        Transaction tx = null;

        try {
            tx = session.beginTransaction();

            // 1. Recuperar Cliente y Veterinario
            Cliente cliente = session.get(Cliente.class, clienteId);
            Veterinario vet = session.get(Veterinario.class, vetId);

            if (cliente == null || vet == null) throw new Exception("Cliente o Vet no existen");

            // 2. Crear Expediente (1:1)
            ExpedienteClinico exp = new ExpedienteClinico();
            exp.setFechaCreacion(LocalDate.now());
            exp.setHistorial("Alta inicial en el sistema.");

            // 3. Crear Mascota vinculada
            Mascota mascota = new Mascota();
            mascota.setNombre(nombreMascota);
            mascota.setPeso(peso);
            mascota.setDueño(cliente);
            mascota.setExpediente(exp);

            // 4. VALIDACIÓN MANUAL ANTES DE GUARDAR
            ValidatorFactory factory = Validation.buildDefaultValidatorFactory();
            Validator validator = factory.getValidator();
            Set<ConstraintViolation<Mascota>> violations = validator.validate(mascota);

            if (!violations.isEmpty()) {
                throw new Exception("Validación fallida: " + violations.iterator().next().getMessage());
            }

            // 5. Persistir (Hibernate guarda Mascota y Expediente por el Cascade)
            session.persist(mascota);

            tx.commit(); // O todo o nada
            System.out.println("Éxito: Mascota y Expediente creados.");

        } catch (Exception e) {
            if (tx != null) tx.rollback(); // ¡SI FALLA ALGO, VOLVEMOS ATRÁS!
            System.err.println("Error en la operación: " + e.getMessage());
            throw e;
        } finally {
            session.close();
        }
    }
}

