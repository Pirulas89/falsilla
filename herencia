package com.hibernate.gui;

import java.util.List;
import org.hibernate.Session;
import org.hibernate.Transaction;
import com.hibernate.gui.model.*;
import com.hibernate.gui.util.HibernateUtil;

public class AppGestionEmpleados {

    public static void main(String[] args) {
        
        // 1. CREACIÓN DE OBJETOS (Aquí es donde decides qué es cada uno)
        Comercial c1 = new Comercial();
        c1.setNombre("Ana García");
        c1.setSueldoBase(1500.0);
        c1.setComision(400.0);

        Repartidor r1 = new Repartidor();
        r1.setNombre("Juan Pérez");
        r1.setSueldoBase(1100.0);
        r1.setZona("Norte");

        // 2. GUARDADO EN BASE DE DATOS
        try (Session session = HibernateUtil.getSessionFactory().openSession()) {
            Transaction tx = session.beginTransaction();
            
            session.persist(c1);
            session.persist(r1);
            
            tx.commit();
            System.out.println("--- Empleados guardados correctamente ---\n");
        } catch (Exception e) {
            e.printStackTrace();
        }

        // 3. RECUPERACIÓN Y POLIMORFISMO
        try (Session session = HibernateUtil.getSessionFactory().openSession()) {
            
            // Pedimos una lista de la clase PADRE (Empleado)
            List<Empleado> lista = session.createQuery("from Empleado", Empleado.class).list();

            System.out.println("LISTADO DE NÓMINAS:");
            System.out.println("-------------------");

            for (Empleado e : lista) {
                // Aquí es donde ocurre la magia del instanceof
                if (e instanceof Comercial com) {
                    double total = com.getSueldoBase() + com.getComision();
                    System.out.println("[COMERCIAL] " + com.getNombre() + 
                                     " | Sueldo Total: " + total + "€");
                } 
                else if (e instanceof Repartidor rep) {
                    System.out.println("[REPARTIDOR] " + rep.getNombre() + 
                                     " | Zona: " + rep.getZona() + 
                                     " | Sueldo: " + rep.getSueldoBase() + "€");
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}

import java.sql.*;

public class RegistroCompletoEscuela {

    static final String URL = "jdbc:mysql://localhost:3306/escuela";
    static final String USER = "root";
    static final String PASS = "admin";

    public static void main(String[] args) {
        
        try (Connection conn = DriverManager.getConnection(URL, USER, PASS)) {
            conn.setAutoCommit(false); // TRASACCION: O se guarda todo o nada

            // 1. CREAR EL CURSO Y RECUPERAR SU ID
            String sqlCurso = "INSERT INTO cursos (titulo) VALUES (?)";
            int idCurso = -1;
            try (PreparedStatement ps = conn.prepareStatement(sqlCurso, Statement.RETURN_GENERATED_KEYS)) {
                ps.setString(1, "Programación Java 101");
                ps.executeUpdate();
                ResultSet rs = ps.getGeneratedKeys();
                if (rs.next()) idCurso = rs.getInt(1);
            }

            // 2. CREAR EL ESTUDIANTE Y RECUPERAR SU ID
            String sqlEst = "INSERT INTO estudiantes (nombre) VALUES (?)";
            int idEstudiante = -1;
            try (PreparedStatement ps = conn.prepareStatement(sqlEst, Statement.RETURN_GENERATED_KEYS)) {
                ps.setString(1, "Lucía Fernández");
                ps.executeUpdate();
                ResultSet rs = ps.getGeneratedKeys();
                if (rs.next()) idEstudiante = rs.getInt(1);
            }

            // 3. UNIRLOS EN LA TABLA INTERMEDIA (La "relación")
            if (idCurso != -1 && idEstudiante != -1) {
                String sqlRelacion = "INSERT INTO estudiantes_cursos (id_estudiante, id_curso) VALUES (?, ?)";
                try (PreparedStatement ps = conn.prepareStatement(sqlRelacion)) {
                    ps.setInt(1, idEstudiante);
                    ps.setInt(2, idCurso);
                    ps.executeUpdate();
                }
                System.out.println("Inscripción completada: Lucía en Programación Java.");
            }

            conn.commit(); // Confirmamos todos los cambios a la vez
            
            // 4. CONSULTA FINAL PARA COMPROBAR
            mostrarDatos(conn, idEstudiante);

        } catch (SQLException e) {
            System.err.println("Error, haciendo rollback: " + e.getMessage());
        }
    }

    private static void mostrarDatos(Connection conn, int idEst) throws SQLException {
        String sql = "SELECT e.nombre, c.titulo FROM estudiantes e " +
                     "JOIN estudiantes_cursos ec ON e.id = ec.id_estudiante " +
                     "JOIN cursos c ON c.id = ec.id_curso " +
                     "WHERE e.id = ?";
        try (PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setInt(1, idEst);
            ResultSet rs = ps.executeQuery();
            while (rs.next()) {
                System.out.println("Resultado: " + rs.getString("nombre") + " -> " + rs.getString("titulo"));
            }
        }
    }
}

